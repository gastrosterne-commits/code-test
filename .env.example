# ── Modus ────────────────────────────────────────────────────────────────────
# DEV_MODE=true  → Formular wird befüllt aber NICHT abgesendet (nur prüfen)
# DEV_MODE=false → Produktionsbetrieb (du sendest manuell ab, dann ENTER)
DEV_MODE=true

# ── IMAP-Zugangsdaten ────────────────────────────────────────────────────────
# Kopiere diese Datei als ".env" und trage deine Zugangsdaten ein.

IMAP_SERVER=outlook.office365.com
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_USERNAME=deine@email.de
IMAP_PASSWORD=dein_passwort
IMAP_MAILBOX=INBOX
